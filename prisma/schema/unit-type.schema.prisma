model UnitType {
    id      Int     @id @default(autoincrement())
    name    String  // legacy / fallback ("Kilogramm")
    name_uz String? // "Kilogramm"
    name_ru String? // "Килограмм"
    symbol  String  // "kg"

    products      Product[]
    product_items ProductItem[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("unittype")
}
