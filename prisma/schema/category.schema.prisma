model Category {
  id      Int     @default(autoincrement()) @id
  name    String?
  name_uz String?
  name_ru String?

  desc  String?
  image  String?
  work_status     WORK_STATUS @default(WORKING)

  products Product[]

  createdt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@map("category")

}