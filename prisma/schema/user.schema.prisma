model User {
  id    Int     @default(autoincrement()) @id
  fullname  String?
  image  String?
  phone String  @unique


  orders Order[]
  promo_code_uses PromoCodeUse[]

  role Role @default(USER)
  createdt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@map("user")
}